    ],
    "entities": [
      { "name": "Member", "domain": "member", "keyFields": ["memberId", "name", "email", "phone", "gender", "birthDate", "status", "gymId"] },
      { "name": "Gym", "domain": "platform", "keyFields": ["gymId", "name", "address", "phone", "status", "contractEndDate"] },
      { "name": "Admin", "domain": "auth", "keyFields": ["adminId", "email", "role", "gymId"] },
      { "name": "Ticket", "domain": "ticket", "keyFields": ["ticketId", "memberId", "gymId", "ticketType", "startDate", "expiryDate", "remainingCount", "status"] },
      { "name": "TicketTemplate", "domain": "settings", "keyFields": ["templateId", "name", "category", "visitsPerMonth", "price"] },
      { "name": "TicketPayment", "domain": "ticket", "keyFields": ["paymentId", "ticketId", "cardAmount", "cashAmount", "paidAt"] },
      { "name": "TicketHold", "domain": "ticket", "keyFields": ["holdId", "ticketId", "startDate", "endDate"] },
