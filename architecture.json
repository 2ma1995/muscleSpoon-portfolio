        ]
      },
      {
        "name": "AdminController",
        "basePath": "/api/admins",
        "domain": "platform",
        "endpoints": [
          { "method": "GET", "path": "/", "description": "관리자 목록" },
          { "method": "POST", "path": "/", "description": "관리자 생성" },
          { "method": "PUT", "path": "/{id}", "description": "관리자 수정" },
          { "method": "DELETE", "path": "/{id}", "description": "관리자 삭제" }
        ]
      },
      {
        "name": "PlatformMessageController",
        "basePath": "/api/platform/messages",
        "domain": "platform",
        "endpoints": [
          { "method": "POST", "path": "/", "description": "메시지 발송" },
          { "method": "GET", "path": "/my", "description": "내 메시지 목록" },
          { "method": "GET", "path": "/", "description": "전체 메시지 목록" },
