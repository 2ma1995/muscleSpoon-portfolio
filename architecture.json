      { "name": "PtWorkout", "domain": "pt", "keyFields": ["workoutId", "lessonId"] },
      { "name": "PtExercise", "domain": "pt", "keyFields": ["exerciseId", "workoutId", "name", "sets", "reps", "weight"] },
      { "name": "PtJournal", "domain": "pt", "keyFields": ["journalId", "lessonId", "memberId", "coachingPoints", "memo"] },
      { "name": "InBodyRecord", "domain": "member", "keyFields": ["inBodyId", "memberId", "measuredAt", "height", "weight", "muscleMass", "bodyFat", "bmi"] },
      { "name": "PrRecord", "domain": "member", "keyFields": ["recordId", "memberId", "exerciseName", "record"] },
      { "name": "Notice", "domain": "notice", "keyFields": ["noticeId", "gymId", "title", "content", "active", "createdAt"] },
      { "name": "Holiday", "domain": "settings", "keyFields": ["holidayId", "gymId", "date", "memo", "isHoliday"] },
      { "name": "Locker", "domain": "locker", "keyFields": ["number", "gymId", "memberId", "status"] },
      { "name": "Setting", "domain": "settings", "keyFields": ["settingId", "gymId", "lessonCapacity", "ticketValidityDays"] },
      { "name": "ExtraTemplate", "domain": "settings", "keyFields": ["templateId", "gymId", "name", "type", "price"] },
      { "name": "ExtraPurchase", "domain": "ticket", "keyFields": ["purchaseId", "memberId", "templateId", "quantity", "totalPrice", "status"] },
      { "name": "ChatRoom", "domain": "chat", "keyFields": ["roomId", "gymId", "gymName", "lastMessageAt"] },
      { "name": "ChatMessage", "domain": "chat", "keyFields": ["messageId", "roomId", "senderRole", "content", "isRead", "sentAt"] },
