      { "name": "LessonTemplate", "domain": "settings", "keyFields": ["templateId", "name", "category", "capacity", "duration"] },
      { "name": "Booking", "domain": "lesson", "keyFields": ["bookingId", "memberId", "lessonId", "status", "createdAt", "canceledAt"] },
