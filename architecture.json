    "services": [
      "AuthService", "MemberService", "MemberActivationScheduler",
      "GymService", "TicketService", "TicketTemplateService",
      "BookingService", "LessonService", "LessonTemplateService",
      "DailyWorkoutService", "PtWorkoutService", "PtService", "PtJournalService",
      "InBodyService", "PrRecordService", "NoticeService", "HolidayService",
      "DashboardService", "SettingService", "StatisticsService",
      "ExtraTemplateService", "ExtraPurchaseService",
      "InstructorService", "LockerService",
      "ChatRoomService", "ChatMessageService",
      "PushNotificationService", "PlatformSettingService",
      "LessonReminderScheduler"
